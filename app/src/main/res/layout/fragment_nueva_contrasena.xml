<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Flecha atrás -->
        <ImageButton
            android:id="@+id/btnAtras"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@color/bg_card"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/btn_atras"
            app:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Ícono -->
        <ImageView
            android:id="@+id/imgIcono"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_circle_blue"
            android:padding="16dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            android:contentDescription="@string/content_desc_logo"
            app:tint="@color/text_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnAtras" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Nueva contrasena"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgIcono" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Crea una contrasena segura para tu cuenta"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

        <!-- Campo Nueva Contraseña -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNuevaContrasena"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:hint="Nueva contrasena"
            app:boxBackgroundColor="@color/bg_input"
            app:boxStrokeColor="@color/border_soft"
            app:hintTextColor="@color/text_hint"
            app:passwordToggleEnabled="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNuevaContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Indicador fortaleza -->
        <ProgressBar
            android:id="@+id/progressFortaleza"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:max="3"
            android:progress="0"
            android:progressTint="@color/red"
            android:progressBackgroundTint="@color/border_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilNuevaContrasena" />

        <TextView
            android:id="@+id/tvFortaleza"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ingresa una contrasena"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressFortaleza" />

        <!-- Campo Confirmar Contraseña -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmarContrasena"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Confirmar contrasena"
            app:boxBackgroundColor="@color/bg_input"
            app:boxStrokeColor="@color/border_soft"
            app:hintTextColor="@color/text_hint"
            app:passwordToggleEnabled="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFortaleza">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmarContrasena"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Requisitos -->
        <LinearLayout
            android:id="@+id/layoutRequisitos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/bg_card"
            android:orientation="vertical"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilConfirmarContrasena">

            <TextView
                android:id="@+id/tvReq1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○  Minimo 8 caracteres"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvReq2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○  Al menos una letra mayuscula"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvReq3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○  Al menos un numero"
                android:textColor="@color/text_hint"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Botón Cambiar -->
        <Button
            android:id="@+id/btnCambiar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/blue"
            android:text="Cambiar contrasena"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutRequisitos" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressCambiar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:indeterminateTint="@color/blue"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnCambiar" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>